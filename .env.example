GRAVITINO_PORT=8090
IRC_PORT=9001
IRC_CATALOG_NAME=gravitino_irc
IRC_WAREHOUSE=s3://warehouse/

MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_ROOT_PASSWORD=gravitino_root
MYSQL_DATABASE=iceberg_catalog
MYSQL_USER=iceberg
MYSQL_PASSWORD=iceberg_password

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_BUCKET=warehouse
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9002

SPARK_UI_PORT=4040
TRINO_PORT=8080
JUPYTER_PORT=8888
JUPYTER_TOKEN=

GRAVITINO_MEM=-Xms1g -Xmx2g -XX:MaxMetaspaceSize=512m
IRC_MEM=-Xms512m -Xmx1g -XX:MaxMetaspaceSize=256m
